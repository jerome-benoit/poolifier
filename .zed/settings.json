// Zed project settings for poolifier
//
// JS/TS: Biome format → ESLint --fix
// JSON, JSONC: Biome
// Markdown, YAML: Prettier
{
  "format_on_save": "on",

  "languages": {
    // ── TypeScript (covers .ts and .tsx) ──────────────────────
    "TypeScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.fixAll.eslint" }
      ]
    },
    // ── JavaScript (covers .js, .jsx, .cjs, .mjs) ────────────
    "JavaScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.fixAll.eslint" }
      ]
    },
    // ── JSON / JSONC ──────────────────────────────────────────
    "JSON": {
      "formatter": {
        "language_server": { "name": "biome" }
      }
    },
    "JSONC": {
      "formatter": {
        "language_server": { "name": "biome" }
      }
    },
    // ── Markdown ──────────────────────────────────────────────
    "Markdown": {
      "formatter": "prettier"
    },
    // ── YAML ──────────────────────────────────────────────────
    "YAML": {
      "formatter": "prettier"
    }
  },

  "lsp": {
    "eslint": {
      "settings": {
        "workingDirectory": {
          "mode": "auto"
        }
      }
    }
  }
}
